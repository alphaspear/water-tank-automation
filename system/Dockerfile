FROM python:3.12-slim

# =====================================================
# SYSTEM
# =====================================================

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# =====================================================
# WORKDIR
# =====================================================

WORKDIR /app

# =====================================================
# INSTALL DEPENDENCIES
# =====================================================

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# =====================================================
# COPY APP
# =====================================================

COPY . .

# =====================================================
# PORT
# =====================================================

EXPOSE 80

# =====================================================
# START
# =====================================================

CMD [
    "uvicorn",
    "main:app",
    "--host",
    "0.0.0.0",
    "--port",
    "80"
]